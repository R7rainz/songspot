# Copy to .env to override the dev proxy defaults.
# In dev the app calls "/api" and "/ws", which Vite proxies to BACKEND_URL.
# BACKEND_URL is read by vite.config.ts (proxy target), defaults to :8080.
BACKEND_URL=http://localhost:8080

# For a production build where the backend is reachable directly (CORS enabled),
# point the client at absolute URLs instead of the dev proxy:
# VITE_API_URL=https://api.songspot.example
# VITE_WS_URL=wss://api.songspot.example/ws
